# --------------------------------------------------
# OnTrac WS API Credentials
# Get these from your OnTrac account setup email
# --------------------------------------------------

# Your OnTrac Web Services ID
ONTRAC_WSID=your_wsid_here

# Your OnTrac Web Services Key
ONTRAC_WSKEY=your_wskey_here

# Your OnTrac Customer Branch code (provided by OnTrac during setup)
ONTRAC_CUSTOMER_BRANCH=your_branch_code_here

# --------------------------------------------------
# Server Config
# --------------------------------------------------

# Railway sets this automatically -- do not change it
PORT=3000
